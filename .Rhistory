library(readxl)
library(dplyr)
library(forecast)
library(tseries)
PIB_oferta = read_excel("Cuadros_Prod_Gasto.xlsx", sheet = "PIB oferta anual NORMAL")
PIB_oferta = select(PIB_oferta, 2:22)
PIB_oferta = na.omit(PIB_oferta)
# Primera fila como nombres
colnames(PIB_oferta) = PIB_oferta[1, ]
PIB_oferta = PIB_oferta[-1, ]
# Transponer
datos = as.data.frame(t(PIB_oferta[1:14, 2:21]))
colnames(datos) = PIB_oferta[[1]][1:14]
# Convertir a numérico
datos[] <- lapply(datos, function(x) as.numeric(as.character(x)))
# Última columna = tasa de crecimiento
pib_growth <- datos[[ncol(datos)]]
# Crear serie temporal (ajusta el año inicial si es necesario)
ts_pib <- ts(pib_growth, start = 2006)
print(adf.test(ts_pib))
install.packages("forecast")
library(readxl)
library(dplyr)
library(forecast)
library(tseries)
install.packages("tseries")
library(tseries)
PIB_oferta = read_excel("Cuadros_Prod_Gasto.xlsx", sheet = "PIB oferta anual NORMAL")
PIB_oferta = select(PIB_oferta, 2:22)
PIB_oferta = na.omit(PIB_oferta)
# Primera fila como nombres
colnames(PIB_oferta) = PIB_oferta[1, ]
PIB_oferta = PIB_oferta[-1, ]
# Transponer
datos = as.data.frame(t(PIB_oferta[1:14, 2:21]))
colnames(datos) = PIB_oferta[[1]][1:14]
# Convertir a numérico
datos[] <- lapply(datos, function(x) as.numeric(as.character(x)))
# Última columna = tasa de crecimiento
pib_growth <- datos[[ncol(datos)]]
# Crear serie temporal (ajusta el año inicial si es necesario)
ts_pib <- ts(pib_growth, start = 2006)
print(adf.test(ts_pib))
modelo <- auto.arima(ts_pib)
summary(modelo)
checkresiduals(modelo)
pred <- forecast(modelo, h = 5)
print(pred)
plot(pred)
datos = as.data.frame(t(PIB_oferta[1:14, 2:22]))
